{
  "name": "@agent-stack-ecosystem-kits/marketplace-api",
  "version": "0.0.0",
  "private": true,
  "description": "Wallet-authenticated Circle + Sema agent marketplace API.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.2.0",
    "@x402/core": "^2.15.0",
    "@x402/evm": "^2.15.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "viem": "^2.37.13",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.5",
    "@types/node": "^20.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
