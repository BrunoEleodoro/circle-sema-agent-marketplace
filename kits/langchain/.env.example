# Circle Agent Stack
# Authentication is handled by the Circle CLI itself. There is no Circle API
# key. Before the first demo run, complete the one-time host setup (setup.md
# steps 1-3: CLI install, skill install, login + Terms of Use acceptance).
# See the README "Host setup" section. The CLI stores credentials under
# ~/.circle (override with CIRCLE_CLI_HOME).
# https://developers.circle.com/agent-stack

# Default chain for agent wallet operations (only BASE is supported today)
CIRCLE_CHAIN=BASE

# LangChain Deep Agents uses an LLM provider. Set ONE of the two below. The
# demo picks the provider at runtime based on which key is present.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model override (defaults: claude-sonnet-4-6 / gpt-4o-mini)
# LLM_MODEL=
