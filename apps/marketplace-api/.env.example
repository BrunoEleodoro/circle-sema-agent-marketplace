PORT=3000
MARKETPLACE_DB_PATH=.data/marketplace.sqlite
MARKETPLACE_SESSION_SECRET=change-me
MARKETPLACE_CORS_ORIGIN=*

# Keep 0 for real Circle Gateway x402 delivery.
