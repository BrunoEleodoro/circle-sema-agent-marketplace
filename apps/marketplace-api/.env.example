# treasury wallet first; the API records a seller payout ledger after delivery.
MARKETPLACE_TREASURY_WALLET=
MARKETPLACE_ADMIN_TOKEN=
CIRCLE_GATEWAY_FACILITATOR_URL=https://gateway-api.circle.com
BASE_RPC_URL=
