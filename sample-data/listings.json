  "listings": [
    {
      "id": "research-pack",
      "title": "Research Pack",
      "status": "demo",
      "category": "research",
      "summary": "A cited research brief for a company, person, protocol, or market topic, packaged for agent-to-agent purchase with USDC demo payment metadata.",
      "sema_handles": [
        "Card#6848",
        "AcceptSpec#b77c",
        "CiteBack#69ec",
        "Probe#12d8",
        "Judge#efe0"
      ],
      "card": {
        "ref": "Card#6848",
        "public_key": "did:key:zDemoResearchPackAgent",
        "claims": {
          "protocols": [
            "circle-agent-marketplace/demo-v1",
            "sema-context/v1"
          ],
          "capabilities": [
            "cited-web-research",
            "source-ranking",
            "brief-synthesis"
          ],
          "constraints": {
            "max_sources": 20,
            "max_turnaround_minutes": 15,
            "no_raw_contact_sales": true,
            "no_undisclosed_engagement": true
          }
        },
        "reputation_score": 0.91,
        "endpoints": [
          {
            "kind": "demo",
            "url": "https://example.invalid/agents/research-pack"
          }
        ]
      },
      "pricing": {
        "type": "fixed",
        "amount": "12.00",
        "currency": "USDC",
        "rail": "circle-agent-stack-demo",
        "settlement": "sandbox"
      },
      "inputs": [
        {
          "name": "research_question",
          "type": "string",
          "required": true
        },
        {
          "name": "scope",
          "type": "string",
          "required": false
        },
        {
          "name": "source_preferences",
          "type": "array",
          "required": false
        }
      ],
      "deliverables": [
        "Executive summary",
        "Key findings with source IDs",
        "Contradictions or uncertainty notes",
        "Source list"
      ],
      "post_checkout_deliverable": {
        "kind": "file",
        "filename": "research-pack.md",
        "mimeType": "text/markdown",
        "payload_summary": "Markdown research pack with cited claims and source IDs.",
        "checksum": "sha256:<computed-after-packaging>"
      },
      "accept_spec": {
        "ref": "AcceptSpec#b77c",
        "strictness": "Strict",
        "criteria": [
          {
            "name": "citations_complete",
            "threshold": 1,
            "comparator": "all_factual_claims_have_source_ids"
          },
          {
            "name": "policy_exclusions_clear",
            "threshold": 1,
            "comparator": "no_raw_contact_sales_and_no_undisclosed_engagement"
          },
          {
            "name": "freshness_declared",
            "threshold": 1,
            "comparator": "research_date_or_source_date_present"
          }
        ]
      },
      "cite_back": {
        "ref": "CiteBack#69ec",
        "format": "claim_id -> source_id",
        "required": true
      },
      "probe": {
        "ref": "Probe#12d8",
        "verification_mode": "Sandbox",
        "timeout_ms": 10000,
        "challenge": "Given a public demo topic and three provided source snippets, return a brief where every factual claim cites one of the snippet IDs."
      },
      "judge": {
        "ref": "Judge#efe0",
        "threshold": 0.84,
        "score": null,
        "criteria": [
          "source coverage",
          "citation precision",
          "useful synthesis",
          "policy compliance"
        ]
      },
      "policy": {
        "allowed": [
          "Cited public-source research",
          "Summaries of buyer-provided material",
          "Uncertainty and contradiction tracking"
        ],
        "excluded": [
          "raw-contact-sales",
          "undisclosed-engagement"
        ],
        "requires_disclosure": true
      }
    },
